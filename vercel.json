{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "ADMIN_USER": "@admin_user",
    "ADMIN_PASS": "@admin_pass"
  }
}
